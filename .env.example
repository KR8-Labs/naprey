# Go High Level integration — copy this file to .env and fill in the real values.
# See GHL_INTEGRATION.md for step-by-step instructions on where to find each value.

# Contact form embed URL (from GHL: Sites → Forms → your form → Integrate)
PUBLIC_GHL_FORM_URL=https://api.leadconnectorhq.com/widget/form/REPLACE_WITH_YOUR_FORM_ID

# Calendar / booking embed URL (from GHL: Calendars → your calendar → Embed)
PUBLIC_GHL_CALENDAR_URL=https://api.leadconnectorhq.com/widget/booking/REPLACE_WITH_YOUR_CALENDAR_ID

# Chat widget location ID (from GHL: Sites → Chat Widget → Install → data-location-id)
PUBLIC_GHL_LOCATION_ID=REPLACE_WITH_YOUR_LOCATION_ID
