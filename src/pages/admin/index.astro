---
// Standalone shell — deliberately NOT <Base>, which pulls in the marketing
// site's nav, JSON-LD, reveal system, and GHL chat widget. This is an
// internal tool: functions/admin/_middleware.ts gates who can reach it with
// a shared password + signed session cookie, so no client-side auth code
// lives on this page itself — only the logout call below.
import '../../styles/global.css';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Content admin — Naprey Almario</title>
  </head>
  <body>
    <div class="admin-shell">
      <header class="admin-head">
        <div>
          <h1>Content admin</h1>
          <p class="admin-sub">Edit site copy and photos, then publish.</p>
        </div>
        <button type="button" id="logout-btn" class="logout-btn">Log out</button>
      </header>

      <div id="loading" class="admin-loading">Loading current content…</div>
      <div id="error" class="admin-error" hidden></div>

      <form id="admin-form" class="admin-form" hidden>
        <div id="sections"></div>

        <div class="publish-bar">
          <div id="banner" class="banner" hidden role="status"></div>
          <div class="publish-bar-row">
            <button type="button" id="save-all-btn" class="save-all-btn">Save all</button>
            <button type="submit" id="publish-btn" class="publish-btn">Publish changes</button>
            <span id="publish-hint" class="publish-hint"></span>
          </div>
        </div>
      </form>
    </div>

    <dialog id="diff-dialog" class="diff-dialog">
      <h2>Review changes</h2>
      <p class="diff-intro">This saves the changes below locally. It doesn't publish them yet — you'll still need to click "Publish changes" afterward.</p>
      <ul id="diff-list" class="diff-list"></ul>
      <div class="diff-actions">
        <button type="button" id="diff-cancel" class="btn-secondary">Cancel</button>
        <button type="button" id="diff-confirm" class="publish-btn">Confirm &amp; save all</button>
      </div>
    </dialog>

    <!-- Reused across image-upload controls -->
    <template id="tpl-image-field">
      <div class="img-field">
        <div class="img-preview-wrap">
          <img class="img-preview" alt="" />
        </div>
        <div class="img-controls">
          <label class="btn-file">
            Replace photo
            <input type="file" accept="image/png,image/jpeg,image/webp" class="img-input" />
          </label>
          <span class="img-status"></span>
        </div>
      </div>
    </template>

    <script>
      import { adminSchema, type SectionDef, type FieldDef } from './_schema';

      // ── Types ──────────────────────────────────────────────────────────
      type Json = Record<string, any>;

      // ── Dot-path helpers ───────────────────────────────────────────────
      function getPath(obj: Json, path: string): any {
        return path.split('.').reduce((o, k) => (o == null ? undefined : o[k]), obj);
      }
      function setPath(obj: Json, path: string, value: any): void {
        const keys = path.split('.');
        let cur = obj;
        for (let i = 0; i < keys.length - 1; i++) {
          if (cur[keys[i]] == null) cur[keys[i]] = {};
          cur = cur[keys[i]];
        }
        cur[keys[keys.length - 1]] = value;
      }

      // ── Global state ───────────────────────────────────────────────────
      // `content` is the live, editable state. `originalContent` is the
      // last-*saved* baseline (updated by a section's own Save button, or by
      // confirming Save all) — NOT necessarily what's live on the site.
      // Comparing content vs. originalContent at a given path is how we know
      // whether a section has unsaved edits.
      let content: Json = {};
      let originalContent: Json = {};

      function deepEqual(a: unknown, b: unknown): boolean {
        return JSON.stringify(a) === JSON.stringify(b);
      }
      function anyDirty(): boolean {
        return !deepEqual(content, originalContent);
      }

      // Section key -> its rendered card element, so validation/save-all can
      // scroll a user straight to the problem instead of leaving them to hunt
      // through a very long page for a banner they can't see.
      const sectionCards = new Map<string, HTMLElement>();
      // Registered by every section builder; called after a bulk "Save all"
      // confirm so each section's own Save button reflects the new clean state.
      const saveStateRefreshers: Array<() => void> = [];

      function scrollToSection(key: string) {
        const el = sectionCards.get(key);
        if (!el) return;
        el.scrollIntoView({ behavior: 'smooth', block: 'center' });
        el.classList.add('card--flash');
        setTimeout(() => el.classList.remove('card--flash'), 1600);
      }

      // ── DOM refs ────────────────────────────────────────────────────────
      const loadingEl = document.getElementById('loading')!;
      const errorEl = document.getElementById('error')!;
      const formEl = document.getElementById('admin-form') as HTMLFormElement;
      const sectionsEl = document.getElementById('sections')!;
      const bannerEl = document.getElementById('banner')!;
      const publishBtn = document.getElementById('publish-btn') as HTMLButtonElement;
      const publishHint = document.getElementById('publish-hint')!;
      const saveAllBtn = document.getElementById('save-all-btn') as HTMLButtonElement;
      const logoutBtn = document.getElementById('logout-btn') as HTMLButtonElement;
      const imgFieldTpl = document.getElementById('tpl-image-field') as HTMLTemplateElement;
      const diffDialog = document.getElementById('diff-dialog') as HTMLDialogElement;

      logoutBtn.addEventListener('click', async () => {
        await fetch('/api/logout', { method: 'POST' });
        location.reload();
      });
      const diffListEl = document.getElementById('diff-list')!;
      const diffCancelBtn = document.getElementById('diff-cancel') as HTMLButtonElement;
      const diffConfirmBtn = document.getElementById('diff-confirm') as HTMLButtonElement;

      // Lives in the sticky bottom bar now, so it's always on screen — no
      // need to scroll to it the way a top-of-page banner would've required.
      // Auto-dismisses after 3s (shrinking away, not just vanishing) so it
      // doesn't sit there permanently once read.
      let bannerHideTimer: ReturnType<typeof setTimeout> | null = null;
      let bannerRemoveTimer: ReturnType<typeof setTimeout> | null = null;
      const BANNER_TRANSITION_MS = 300;

      function showBanner(kind: 'success' | 'error', message: string) {
        if (bannerHideTimer) clearTimeout(bannerHideTimer);
        if (bannerRemoveTimer) clearTimeout(bannerRemoveTimer);

        bannerEl.textContent = message;
        bannerEl.className = `banner banner--${kind}`; // resets any --collapsed from a prior message
        bannerEl.hidden = false;

        bannerHideTimer = setTimeout(() => {
          bannerEl.classList.add('banner--collapsed');
          bannerRemoveTimer = setTimeout(() => {
            bannerEl.hidden = true;
            bannerEl.classList.remove('banner--collapsed');
          }, BANNER_TRANSITION_MS);
        }, 3000);
      }

      // ── Field builders ──────────────────────────────────────────────────
      // Every builder takes an `onDirty` callback instead of touching a bare
      // global flag — each section wires this to its own local save-state
      // refresh, so its Save button reacts immediately to edits within it.
      function buildTextInput(value: string, onChange: (v: string) => void, onDirty: () => void): HTMLInputElement {
        const input = document.createElement('input');
        input.type = 'text';
        input.className = 'field-input';
        input.value = value ?? '';
        input.addEventListener('input', () => { onChange(input.value); onDirty(); });
        return input;
      }

      function buildTextarea(value: string, onChange: (v: string) => void, onDirty: () => void): HTMLTextAreaElement {
        const ta = document.createElement('textarea');
        ta.className = 'field-textarea';
        ta.rows = 3;
        ta.value = value ?? '';
        ta.addEventListener('input', () => { onChange(ta.value); onDirty(); });
        return ta;
      }

      type ImgDims = { w: number; h: number };

      function buildImageField(
        value: string | undefined,
        onChange: (v: string, dims?: ImgDims) => void,
        onDirty: () => void
      ): HTMLElement {
        const node = imgFieldTpl.content.cloneNode(true) as HTMLElement;
        const wrap = node.querySelector('.img-field') as HTMLElement;
        const img = node.querySelector('.img-preview') as HTMLImageElement;
        const input = node.querySelector('.img-input') as HTMLInputElement;
        const status = node.querySelector('.img-status') as HTMLElement;

        const resolveSrc = (v: string | undefined) => {
          if (!v) return '';
          if (/^https?:\/\//.test(v)) return v;
          return `/${v.replace(/^\/+/, '')}`;
        };
        img.src = resolveSrc(value);
        img.alt = '';

        input.addEventListener('change', async () => {
          const file = input.files?.[0];
          if (!file) return;
          status.textContent = 'Uploading…';
          try {
            const { blob, width, height } = await resizeImageForUpload(file);
            const url = await uploadImage(blob);
            img.src = url;
            onChange(url, { w: width, h: height });
            onDirty();
            status.textContent = 'Uploaded';
            setTimeout(() => { status.textContent = ''; }, 2000);
          } catch (err) {
            status.textContent = 'Upload failed — try again';
            console.error(err);
          }
        });

        return wrap;
      }

      // Downscale + re-encode before upload so a phone photo (often several
      // MB, 4000px+) doesn't get committed to storage at full size. Pure
      // Canvas APIs — no new dependency.
      async function resizeImageForUpload(
        file: File,
        maxDim = 2000,
        quality = 0.85
      ): Promise<{ blob: Blob; width: number; height: number }> {
        const bitmap = await createImageBitmap(file);
        let width = bitmap.width;
        let height = bitmap.height;
        if (width > maxDim || height > maxDim) {
          const scale = maxDim / Math.max(width, height);
          width = Math.round(width * scale);
          height = Math.round(height * scale);
        }

        const canvas = document.createElement('canvas');
        canvas.width = width;
        canvas.height = height;
        const ctx = canvas.getContext('2d')!;
        ctx.drawImage(bitmap, 0, 0, width, height);

        const toBlob = (type: string) =>
          new Promise<Blob | null>((resolve) => canvas.toBlob(resolve, type, quality));

        let blob = await toBlob('image/webp');
        // Some browsers silently fall back to PNG for an unsupported
        // requested type instead of erroring — re-encode as JPEG instead so
        // uploads stay small.
        if (!blob || blob.type !== 'image/webp') blob = await toBlob('image/jpeg');
        if (!blob) throw new Error('Could not process image');

        return { blob, width, height };
      }

      async function uploadImage(blob: Blob): Promise<string> {
        const form = new FormData();
        const ext = blob.type === 'image/webp' ? 'webp' : 'jpg';
        form.append('file', blob, `upload.${ext}`);

        const res = await fetch('/api/upload-image', { method: 'POST', body: form });
        if (!res.ok) throw new Error('Image upload failed');
        const data = await res.json();
        return data.url as string;
      }

      function buildField(field: FieldDef, item: Json, onDirty: () => void): HTMLElement {
        const wrap = document.createElement('label');
        wrap.className = 'field';
        const labelEl = document.createElement('span');
        labelEl.className = 'field-label';
        labelEl.textContent = field.label;
        wrap.appendChild(labelEl);

        const value = getPath(item, field.key);
        const onChange = (v: string) => { setPath(item, field.key, v); };

        if (field.type === 'textarea') {
          wrap.appendChild(buildTextarea(value, onChange, onDirty));
        } else if (field.type === 'image') {
          wrap.appendChild(buildImageField(value, onChange, onDirty));
        } else {
          wrap.appendChild(buildTextInput(value, onChange, onDirty));
        }
        return wrap;
      }

      // Every section card gets the same header: title + a Save button that's
      // only enabled while this section actually differs from its last-saved
      // baseline, plus a status line for "unsaved" / a validation error /
      // a brief "Saved" confirmation. `isDirty`/`onSave` are section-specific;
      // returns a `refresh()` you call after any edit within the section.
      function buildCardHeader(
        card: HTMLElement,
        title: string,
        isDirty: () => boolean,
        onSave: () => string | null // returns an error message, or null on success
      ): { refresh: () => void; onDirty: () => void } {
        const header = document.createElement('div');
        header.className = 'card-header';
        const h = document.createElement('h2');
        h.textContent = title;
        header.appendChild(h);

        const saveWrap = document.createElement('div');
        saveWrap.className = 'card-save-wrap';
        const saveBtn = document.createElement('button');
        saveBtn.type = 'button';
        saveBtn.className = 'card-save-btn';
        saveBtn.textContent = 'Save';
        const status = document.createElement('span');
        status.className = 'card-save-status';
        saveWrap.append(status, saveBtn);
        header.appendChild(saveWrap);
        card.appendChild(header);

        const refresh = () => {
          const dirty = isDirty();
          saveBtn.disabled = !dirty;
          if (dirty) {
            status.textContent = 'Unsaved changes';
            status.className = 'card-save-status card-save-status--dirty';
          } else if (status.className.includes('--error')) {
            // leave an error message visible until the next edit
          } else {
            status.textContent = '';
            status.className = 'card-save-status';
          }
        };

        saveBtn.addEventListener('click', () => {
          const problem = onSave();
          if (problem) {
            status.textContent = problem;
            status.className = 'card-save-status card-save-status--error';
            return;
          }
          status.textContent = 'Saved';
          status.className = 'card-save-status card-save-status--ok';
          saveBtn.disabled = true;
          setTimeout(() => { if (!isDirty()) refresh(); }, 1800);
        });

        refresh();
        saveStateRefreshers.push(refresh);
        return { refresh, onDirty: refresh };
      }

      // ── Section builders ─────────────────────────────────────────────────
      function buildFieldsSection(section: Extract<SectionDef, { kind: 'fields' }>): HTMLElement {
        const item = getPath(content, section.key) ?? {};
        const card = document.createElement('section');
        card.className = 'card';

        const isDirty = () => !deepEqual(getPath(content, section.key), getPath(originalContent, section.key));
        const onSave = () => {
          const problem = validateSection(section);
          if (problem) return problem;
          setPath(originalContent, section.key, structuredClone(getPath(content, section.key)));
          return null;
        };
        const { onDirty } = buildCardHeader(card, section.label, isDirty, onSave);

        section.fields.forEach((f) => card.appendChild(buildField(f, item, onDirty)));
        sectionCards.set(section.key, card);
        return card;
      }

      function buildStringListSection(section: Extract<SectionDef, { kind: 'string-list' }>): HTMLElement {
        const card = document.createElement('section');
        card.className = 'card';

        const isDirty = () => !deepEqual(getPath(content, section.key), getPath(originalContent, section.key));
        const onSave = () => {
          const problem = validateSection(section);
          if (problem) return problem;
          setPath(originalContent, section.key, structuredClone(getPath(content, section.key)));
          return null;
        };
        const { onDirty } = buildCardHeader(card, section.label, isDirty, onSave);

        const list = (getPath(content, section.key) as string[]) ?? [];
        const itemsWrap = document.createElement('div');
        itemsWrap.className = 'list-items';
        card.appendChild(itemsWrap);

        const render = () => {
          itemsWrap.innerHTML = '';
          list.forEach((val, i) => {
            const row = document.createElement('div');
            row.className = 'list-item';
            const ta = buildTextarea(val, (v) => { list[i] = v; }, onDirty);
            row.appendChild(ta);
            row.appendChild(buildItemControls(list, i, () => { render(); onDirty(); }));
            itemsWrap.appendChild(row);
          });
        };
        render();

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.className = 'add-btn';
        addBtn.textContent = `+ Add ${section.itemLabel.toLowerCase()}`;
        addBtn.addEventListener('click', () => { list.push(''); render(); onDirty(); });
        card.appendChild(addBtn);

        setPath(content, section.key, list);
        sectionCards.set(section.key, card);
        return card;
      }

      function buildListSection(section: Extract<SectionDef, { kind: 'list' }>): HTMLElement {
        const card = document.createElement('section');
        card.className = 'card';

        const isDirty = () => !deepEqual(getPath(content, section.key), getPath(originalContent, section.key));
        const onSave = () => {
          const problem = validateSection(section);
          if (problem) return problem;
          setPath(originalContent, section.key, structuredClone(getPath(content, section.key)));
          return null;
        };
        const { onDirty } = buildCardHeader(card, section.label, isDirty, onSave);

        const list = (getPath(content, section.key) as Json[]) ?? [];
        const itemsWrap = document.createElement('div');
        itemsWrap.className = 'list-items';
        card.appendChild(itemsWrap);

        const render = () => {
          itemsWrap.innerHTML = '';
          list.forEach((item, i) => {
            const row = document.createElement('div');
            row.className = 'list-item list-item--card';
            const itemTitle = document.createElement('div');
            itemTitle.className = 'list-item-title';
            itemTitle.textContent = `${section.itemLabel} ${i + 1}`;
            row.appendChild(itemTitle);
            section.fields.forEach((f) => row.appendChild(buildField(f, item, onDirty)));
            row.appendChild(buildItemControls(list, i, () => { render(); onDirty(); }));
            itemsWrap.appendChild(row);
          });
        };
        render();

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.className = 'add-btn';
        addBtn.textContent = `+ Add ${section.itemLabel.toLowerCase()}`;
        addBtn.addEventListener('click', () => {
          const blank: Json = {};
          section.fields.forEach((f) => { blank[f.key] = ''; });
          list.push(blank);
          render();
          onDirty();
        });
        card.appendChild(addBtn);

        setPath(content, section.key, list);
        sectionCards.set(section.key, card);
        return card;
      }

      function buildItemControls(list: any[], index: number, rerender: () => void): HTMLElement {
        const controls = document.createElement('div');
        controls.className = 'item-controls';

        const upBtn = document.createElement('button');
        upBtn.type = 'button';
        upBtn.className = 'icon-btn';
        upBtn.textContent = '↑';
        upBtn.disabled = index === 0;
        upBtn.setAttribute('aria-label', 'Move up');
        upBtn.title = 'Move up';
        upBtn.addEventListener('click', () => {
          [list[index - 1], list[index]] = [list[index], list[index - 1]];
          rerender();
        });

        const downBtn = document.createElement('button');
        downBtn.type = 'button';
        downBtn.className = 'icon-btn';
        downBtn.textContent = '↓';
        downBtn.disabled = index === list.length - 1;
        downBtn.setAttribute('aria-label', 'Move down');
        downBtn.title = 'Move down';
        downBtn.addEventListener('click', () => {
          [list[index + 1], list[index]] = [list[index], list[index + 1]];
          rerender();
        });

        const removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'icon-btn icon-btn--danger';
        removeBtn.textContent = '✕';
        removeBtn.setAttribute('aria-label', 'Remove');
        removeBtn.title = 'Remove';
        removeBtn.addEventListener('click', () => {
          if (!confirm('Remove this entry?')) return;
          list.splice(index, 1);
          rerender();
        });

        controls.append(upBtn, downBtn, removeBtn);
        return controls;
      }

      // Gallery gets its own renderer: two nested levels (categories -> items).
      // Unlike other sections, each CATEGORY gets its own Save button (not
      // the whole Gallery at once) — with 40+ photos across 3 categories,
      // one save covering everything would be both a huge diff to review and
      // a huge blast radius for one save-worthy edit. Categories render
      // collapsed by default (<details>) since 40+ expanded photo blocks was
      // the single biggest contributor to an unusably long page.
      function buildGallerySection(): HTMLElement {
        const card = document.createElement('section');
        card.className = 'card';
        const h = document.createElement('h2');
        h.textContent = 'Gallery';
        card.appendChild(h);

        const categories = (getPath(content, 'gallery.categories') as Json[]) ?? [];

        categories.forEach((cat, catIdx) => {
          const catKey = `gallery.categories.${catIdx}`;
          const details = document.createElement('details');
          details.className = 'gallery-category';
          const summary = document.createElement('summary');
          summary.className = 'gallery-category-summary';
          details.appendChild(summary);

          const isDirty = () =>
            !deepEqual(getPath(content, 'gallery.categories')?.[catIdx], getPath(originalContent, 'gallery.categories')?.[catIdx]);
          const onSave = (): string | null => {
            // No required-field validation for gallery items today (alt text
            // is nice-to-have, not blocking) — matches prior behavior.
            const orig = getPath(originalContent, 'gallery.categories') as Json[];
            orig[catIdx] = structuredClone(getPath(content, 'gallery.categories')[catIdx]);
            return null;
          };

          const saveWrap = document.createElement('div');
          saveWrap.className = 'card-save-wrap';
          const saveBtn = document.createElement('button');
          saveBtn.type = 'button';
          saveBtn.className = 'card-save-btn';
          saveBtn.textContent = 'Save';
          const status = document.createElement('span');
          status.className = 'card-save-status';
          saveWrap.append(status, saveBtn);

          const refresh = () => {
            const dirty = isDirty();
            saveBtn.disabled = !dirty;
            summary.querySelector('.gallery-category-name')!.textContent = cat.name || `Category ${catIdx + 1}`;
            summary.querySelector('.gallery-category-count')!.textContent = `${(cat.items ?? []).length} photos${dirty ? ' · unsaved changes' : ''}`;
            if (dirty) {
              status.textContent = 'Unsaved changes';
              status.className = 'card-save-status card-save-status--dirty';
            } else {
              status.textContent = '';
              status.className = 'card-save-status';
            }
          };
          saveBtn.addEventListener('click', (e) => {
            e.preventDefault(); // don't toggle <details> when clicking inside <summary>
            onSave();
            status.textContent = 'Saved';
            status.className = 'card-save-status card-save-status--ok';
            saveBtn.disabled = true;
            setTimeout(() => { if (!isDirty()) refresh(); }, 1800);
          });
          summary.addEventListener('click', (e) => {
            if ((e.target as HTMLElement).closest('.card-save-wrap')) e.preventDefault();
          });

          const nameEl = document.createElement('span');
          nameEl.className = 'gallery-category-name';
          const countEl = document.createElement('span');
          countEl.className = 'gallery-category-count';
          summary.append(nameEl, countEl, saveWrap);

          const body = document.createElement('div');
          body.className = 'gallery-category-body';
          details.appendChild(body);

          const nameField = document.createElement('label');
          nameField.className = 'field';
          const nameLabel = document.createElement('span');
          nameLabel.className = 'field-label';
          nameLabel.textContent = 'Category name';
          nameField.appendChild(nameLabel);
          nameField.appendChild(buildTextInput(cat.name, (v) => { cat.name = v; }, refresh));
          body.appendChild(nameField);

          const itemsWrap = document.createElement('div');
          itemsWrap.className = 'list-items';
          body.appendChild(itemsWrap);

          const items: Json[] = cat.items ?? [];
          const renderItems = () => {
            itemsWrap.innerHTML = '';
            items.forEach((item, i) => {
              const row = document.createElement('div');
              row.className = 'list-item list-item--card';
              const itemTitle = document.createElement('div');
              itemTitle.className = 'list-item-title';
              itemTitle.textContent = `Photo ${i + 1}`;
              row.appendChild(itemTitle);

              const imgField = document.createElement('label');
              imgField.className = 'field';
              const imgLabel = document.createElement('span');
              imgLabel.className = 'field-label';
              imgLabel.textContent = 'Photo';
              imgField.appendChild(imgLabel);
              imgField.appendChild(buildImageField(item.src, (v, dims) => {
                item.src = v;
                if (dims) { item.w = dims.w; item.h = dims.h; }
              }, refresh));
              row.appendChild(imgField);

              const altField = document.createElement('label');
              altField.className = 'field';
              const altLabel = document.createElement('span');
              altLabel.className = 'field-label';
              altLabel.textContent = 'Alt text (for accessibility)';
              altField.appendChild(altLabel);
              altField.appendChild(buildTextInput(item.alt, (v) => { item.alt = v; }, refresh));
              row.appendChild(altField);

              row.appendChild(buildItemControls(items, i, () => { renderItems(); refresh(); }));
              itemsWrap.appendChild(row);
            });
          };
          renderItems();

          const addItemBtn = document.createElement('button');
          addItemBtn.type = 'button';
          addItemBtn.className = 'add-btn';
          addItemBtn.textContent = '+ Add photo';
          addItemBtn.addEventListener('click', () => {
            items.push({ alt: '', label: '' });
            renderItems();
            refresh();
          });
          body.appendChild(addItemBtn);

          cat.items = items;
          refresh();
          saveStateRefreshers.push(refresh);
          sectionCards.set(catKey, details);
          card.appendChild(details);
        });

        setPath(content, 'gallery.categories', categories);
        return card;
      }

      // ── Validation ────────────────────────────────────────────────────
      // Scoped to one section (used by that section's own Save button) — the
      // full-page validate() below is just this looped over every section,
      // now also reporting *which* section failed so callers can scroll to it.
      function validateSection(section: SectionDef): string | null {
        if (section.kind === 'list') {
          const list = (getPath(content, section.key) as Json[]) ?? [];
          for (const item of list) {
            for (const f of section.fields) {
              if (f.required !== false && !getPath(item, f.key)) {
                return `"${section.label}" has an entry missing "${f.label}".`;
              }
            }
          }
        }
        if (section.kind === 'fields') {
          const item = getPath(content, section.key) ?? {};
          for (const f of section.fields) {
            if (f.required !== false && !getPath(item, f.key)) {
              return `"${section.label}" is missing "${f.label}".`;
            }
          }
        }
        return null;
      }

      function validate(): { key: string; message: string } | null {
        for (const section of adminSchema) {
          const message = validateSection(section);
          if (message) return { key: section.key, message };
        }
        return null;
      }

      // ── Diff summary for the "Save all" review dialog ───────────────────
      function summarizeSectionDiff(section: SectionDef): string[] {
        const current = getPath(content, section.key);
        const original = getPath(originalContent, section.key);
        if (deepEqual(current, original)) return [];

        if (section.kind === 'fields') {
          const lines: string[] = [];
          for (const f of section.fields) {
            const cur = getPath(current ?? {}, f.key);
            const orig = getPath(original ?? {}, f.key);
            if (!deepEqual(cur, orig)) lines.push(`${section.label}: "${f.label}" changed`);
          }
          return lines;
        }

        const curLen = (current ?? []).length;
        const origLen = (original ?? []).length;
        const noun = section.kind === 'list' ? section.itemLabel.toLowerCase() : 'entry';
        if (curLen > origLen) return [`${section.label}: ${curLen - origLen} ${noun}(s) added`];
        if (curLen < origLen) return [`${section.label}: ${origLen - curLen} ${noun}(s) removed`];
        return [`${section.label}: entries changed`];
      }

      function summarizeDiff(): string[] {
        const lines: string[] = [];
        for (const section of adminSchema) {
          if (section.key === 'gallery') continue; // handled per-category below
          lines.push(...summarizeSectionDiff(section));
        }
        const categories = (getPath(content, 'gallery.categories') as Json[]) ?? [];
        const originalCategories = (getPath(originalContent, 'gallery.categories') as Json[]) ?? [];
        categories.forEach((cat, i) => {
          if (!deepEqual(cat, originalCategories[i])) {
            lines.push(`Gallery — ${cat.name || `Category ${i + 1}`}: photos changed`);
          }
        });
        return lines;
      }

      // ── Render all sections ──────────────────────────────────────────────
      function renderSections() {
        sectionsEl.innerHTML = '';
        sectionCards.clear();
        saveStateRefreshers.length = 0;
        for (const section of adminSchema) {
          let el: HTMLElement;
          if (section.kind === 'fields') el = buildFieldsSection(section);
          else if (section.kind === 'string-list') el = buildStringListSection(section);
          else if (section.kind === 'list') el = buildListSection(section);
          else el = buildGallerySection();
          sectionsEl.appendChild(el);
        }
      }

      // ── Load ──────────────────────────────────────────────────────────
      async function load() {
        try {
          const res = await fetch('/api/content');
          if (!res.ok) throw new Error(`Failed to load content (${res.status})`);
          content = await res.json();
          originalContent = structuredClone(content);
          renderSections();
          loadingEl.hidden = true;
          formEl.hidden = false;
        } catch (err) {
          loadingEl.hidden = true;
          errorEl.hidden = false;
          errorEl.textContent = err instanceof Error ? err.message : 'Failed to load content.';
        }
      }

      // ── Save all (review diff, then confirm) ────────────────────────────
      saveAllBtn.addEventListener('click', () => {
        bannerEl.hidden = true;
        const problem = validate();
        if (problem) {
          showBanner('error', problem.message);
          scrollToSection(problem.key);
          return;
        }
        const diffLines = summarizeDiff();
        if (diffLines.length === 0) {
          showBanner('success', 'Nothing to save — no changes since your last save.');
          return;
        }
        diffListEl.innerHTML = '';
        diffLines.forEach((line) => {
          const li = document.createElement('li');
          li.textContent = line;
          diffListEl.appendChild(li);
        });
        diffDialog.showModal();
      });

      diffCancelBtn.addEventListener('click', () => diffDialog.close());

      diffConfirmBtn.addEventListener('click', () => {
        originalContent = structuredClone(content);
        saveStateRefreshers.forEach((refresh) => refresh());
        diffDialog.close();
        showBanner('success', 'All changes saved locally. Click "Publish changes" to make them live.');
      });

      // ── Publish ──────────────────────────────────────────────────────────
      formEl?.addEventListener('submit', async (e) => {
        e.preventDefault();
        bannerEl.hidden = true;

        if (anyDirty()) {
          showBanner('error', 'You have unsaved changes. Click "Save all" (or save each section) before publishing.');
          return;
        }

        const problem = validate();
        if (problem) {
          showBanner('error', problem.message);
          scrollToSection(problem.key);
          return;
        }

        publishBtn.disabled = true;
        publishHint.textContent = 'Publishing…';
        try {
          const res = await fetch('/api/save-content', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(content),
          });
          if (res.status === 409) {
            showBanner('error', 'Someone else (or another tab) changed the content since you loaded it. Reload the page to get the latest version before publishing.');
            return;
          }
          if (!res.ok) {
            const text = await res.text().catch(() => '');
            throw new Error(text || `Publish failed (${res.status})`);
          }
          showBanner('success', 'Published! Your changes are being built and will be live on the site in about 1-2 minutes.');
        } catch (err) {
          showBanner('error', err instanceof Error ? err.message : 'Publish failed — please try again.');
        } finally {
          publishBtn.disabled = false;
          publishHint.textContent = '';
        }
      });

      window.addEventListener('beforeunload', (e) => {
        if (anyDirty()) { e.preventDefault(); }
      });

      load();
    </script>

    <style is:global>
      .admin-shell {
        max-width: 780px;
        margin: 0 auto;
        padding: var(--space-lg) var(--space-md) var(--space-2xl);
        font-family: var(--font-body);
        color: var(--ink);
      }
      .admin-head {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-md);
      }
      .admin-head h1 {
        font-family: var(--font-display);
        font-size: var(--text-2xl);
        margin: 0 0 var(--space-2xs);
      }
      .admin-sub { color: var(--ink-soft); margin: 0 0 var(--space-lg); }
      .logout-btn {
        flex: none;
        padding: var(--space-2xs) var(--space-sm);
        border: 1px solid var(--ink-soft);
        border-radius: 8px;
        background: transparent;
        color: var(--ink-soft);
        font-family: var(--font-body);
        font-size: var(--text-sm);
        cursor: pointer;
      }
      .logout-btn:hover { color: var(--ink); border-color: var(--ink); }

      .admin-loading, .admin-error {
        padding: var(--space-md);
        border-radius: 8px;
        background: var(--paper-2);
      }
      .admin-error { color: var(--accent-deep); }

      .banner {
        padding: var(--space-sm) var(--space-md);
        border-radius: 8px;
        margin-bottom: var(--space-md);
        font-weight: 600;
        max-height: 200px;
        opacity: 1;
        overflow: hidden;
        transition: max-height 0.3s ease, opacity 0.25s ease, padding 0.3s ease, margin 0.3s ease;
      }
      .banner--success { background: #e4efe0; color: #1e5c2e; }
      .banner--error { background: #f5dfd8; color: var(--accent-deep); }
      #banner.banner--collapsed {
        max-height: 0;
        opacity: 0;
        padding-block: 0;
        margin-bottom: 0;
      }

      .card {
        background: var(--paper-2);
        border: 1px solid var(--line);
        border-radius: 10px;
        padding: var(--space-md);
        margin-bottom: var(--space-md);
      }
      .card h2 {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        margin: 0;
      }
      .card--flash {
        outline: 2px solid var(--accent);
        outline-offset: 4px;
        transition: outline-color 1.4s ease;
      }

      .card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: var(--space-sm);
        margin-bottom: var(--space-sm);
      }
      .card-save-wrap {
        display: flex;
        align-items: center;
        gap: var(--space-xs);
        flex: none;
      }
      .card-save-btn {
        padding: 0.4rem 0.85rem;
        border: 1px solid var(--accent);
        border-radius: 6px;
        background: var(--paper);
        color: var(--accent-deep);
        font: inherit;
        font-size: var(--text-sm);
        font-weight: 600;
        cursor: pointer;
      }
      .card-save-btn:hover:not(:disabled) { background: var(--accent); color: var(--accent-contrast); }
      .card-save-btn:disabled {
        border-color: var(--line);
        color: var(--ink-soft);
        opacity: 0.5;
        cursor: not-allowed;
      }
      .card-save-status {
        font-size: var(--text-sm);
        white-space: nowrap;
      }
      .card-save-status--dirty { color: var(--accent-deep); }
      .card-save-status--ok { color: #1e5c2e; }
      .card-save-status--error { color: var(--accent-deep); font-weight: 600; }

      .field { display: block; margin-bottom: var(--space-sm); }
      .field-label {
        display: block;
        font-size: var(--text-sm);
        font-weight: 600;
        color: var(--ink-soft);
        margin-bottom: 0.25rem;
      }
      .field-input, .field-textarea {
        width: 100%;
        font: inherit;
        color: inherit;
        padding: 0.5rem 0.65rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--paper);
      }
      .field-textarea { resize: vertical; }

      .list-items { display: flex; flex-direction: column; gap: var(--space-sm); }
      .list-item { display: flex; align-items: flex-start; gap: var(--space-xs); }
      .list-item .field-textarea { flex: 1; }
      .list-item--card {
        flex-direction: column;
        /* .list-item sets align-items: flex-start for its horizontal string-list
           layout (keeps ↑↓✕ controls top-aligned next to a textarea) — override
           back to stretch here so fields fill the card's full width instead of
           shrinking to their content width. */
        align-items: stretch;
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 8px;
        padding: var(--space-sm);
        position: relative;
      }
      .list-item-title {
        font-size: var(--text-sm);
        font-weight: 700;
        color: var(--ink-soft);
        text-transform: uppercase;
        letter-spacing: 0.04em;
        margin-bottom: var(--space-xs);
      }

      .item-controls {
        display: flex;
        gap: 0.35rem;
        align-self: flex-start;
      }
      .list-item--card .item-controls {
        position: absolute;
        top: var(--space-sm);
        right: var(--space-sm);
      }
      .icon-btn {
        width: 28px;
        height: 28px;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--paper);
        cursor: pointer;
      }
      .icon-btn:disabled { opacity: 0.35; cursor: not-allowed; }
      .icon-btn--danger { color: var(--accent-deep); }

      .add-btn {
        margin-top: var(--space-sm);
        padding: 0.5rem 0.9rem;
        border: 1px dashed var(--line);
        border-radius: 6px;
        background: transparent;
        color: var(--ink-soft);
        cursor: pointer;
        font: inherit;
      }
      .add-btn:hover { background: var(--paper); }

      .gallery-category {
        border: 1px solid var(--line);
        border-radius: 8px;
        margin-bottom: var(--space-sm);
        background: var(--paper);
      }
      .gallery-category-summary {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        padding: var(--space-sm);
        cursor: pointer;
        list-style: none;
      }
      .gallery-category-summary::-webkit-details-marker { display: none; }
      .gallery-category-summary::before {
        content: '▸';
        color: var(--ink-soft);
        transition: transform 0.15s ease;
      }
      details[open] > .gallery-category-summary::before { transform: rotate(90deg); }
      .gallery-category-name { font-weight: 700; }
      .gallery-category-count {
        color: var(--ink-soft);
        font-size: var(--text-sm);
        flex: 1;
      }
      .gallery-category-body { padding: 0 var(--space-sm) var(--space-sm); }

      .img-field { display: flex; align-items: center; gap: var(--space-sm); }
      .img-preview-wrap {
        width: 72px;
        height: 72px;
        border-radius: 6px;
        overflow: hidden;
        background: var(--paper-2);
        flex: none;
      }
      .img-preview { width: 100%; height: 100%; object-fit: cover; display: block; }
      .img-controls { display: flex; flex-direction: column; gap: 0.25rem; }
      .btn-file {
        display: inline-block;
        padding: 0.4rem 0.75rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--paper);
        cursor: pointer;
        font-size: var(--text-sm);
      }
      .btn-file input { display: none; }
      .img-status { font-size: var(--text-sm); color: var(--ink-soft); }

      .publish-bar {
        position: sticky;
        bottom: 0;
        display: flex;
        flex-direction: column;
        padding: var(--space-sm) 0;
        background: var(--paper);
        border-top: 1px solid var(--line);
        /* Own stacking context above the section cards scrolling underneath */
        z-index: 1;
      }
      .publish-bar .banner { margin-bottom: var(--space-sm); }
      .publish-bar-row {
        display: flex;
        align-items: center;
        gap: var(--space-sm);
        flex-wrap: wrap;
      }
      .publish-btn {
        padding: 0.75rem 1.5rem;
        border: none;
        border-radius: 6px;
        background: var(--accent);
        color: var(--accent-contrast);
        font: inherit;
        font-weight: 600;
        cursor: pointer;
      }
      .publish-btn:hover { background: var(--accent-deep); }
      .publish-btn:disabled { opacity: 0.6; cursor: not-allowed; }
      .publish-hint { color: var(--ink-soft); font-size: var(--text-sm); }

      .save-all-btn {
        padding: 0.75rem 1.4rem;
        border: 1px solid var(--accent);
        border-radius: 6px;
        background: var(--paper);
        color: var(--accent-deep);
        font: inherit;
        font-weight: 600;
        cursor: pointer;
      }
      .save-all-btn:hover { background: var(--paper-2); }

      .diff-dialog {
        border: none;
        border-radius: 10px;
        padding: 0;
        max-width: min(520px, 90vw);
        width: 100%;
        box-shadow: var(--shadow-md);
      }
      .diff-dialog::backdrop { background: rgba(26, 20, 16, 0.5); }
      .diff-dialog h2 {
        font-family: var(--font-display);
        font-size: var(--text-lg);
        margin: 0;
        padding: var(--space-md) var(--space-md) 0;
      }
      .diff-intro {
        color: var(--ink-soft);
        font-size: var(--text-sm);
        padding: var(--space-xs) var(--space-md) 0;
        max-width: none;
      }
      .diff-list {
        list-style: none;
        margin: 0;
        padding: var(--space-sm) var(--space-md);
        max-height: 40vh;
        overflow-y: auto;
      }
      .diff-list li {
        padding: 0.4rem 0;
        border-bottom: 1px solid var(--line);
        font-size: var(--text-sm);
      }
      .diff-list li:last-child { border-bottom: none; }
      .diff-actions {
        display: flex;
        justify-content: flex-end;
        gap: var(--space-sm);
        padding: var(--space-sm) var(--space-md) var(--space-md);
      }
      .btn-secondary {
        padding: 0.6rem 1.1rem;
        border: 1px solid var(--line);
        border-radius: 6px;
        background: var(--paper);
        color: var(--ink);
        font: inherit;
        cursor: pointer;
      }
      .btn-secondary:hover { background: var(--paper-2); }
    </style>
  </body>
</html>
