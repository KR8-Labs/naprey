---
import { affiliations } from '../data/content';
---

<section id="affiliations" class="section" aria-labelledby="affiliations-heading">
  <div class="container">
    <header>
      <span class="section-label">Community</span>
      <h2 id="affiliations-heading">Affiliations</h2>
    </header>

    <ul class="aff-list" role="list">
      {affiliations.map((item) => (
        <li class="aff-item">
          <span class="aff-dot" aria-hidden="true"></span>
          <span>{item}</span>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .aff-list {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(340px, 100%), 1fr));
    gap: 0.75rem var(--space-lg);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .aff-item {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    font-size: var(--text-base);
    color: var(--clr-text-muted);
    padding-block: 0.35rem;
    border-bottom: 1px solid var(--clr-border);
  }

  .aff-dot {
    flex-shrink: 0;
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--clr-accent);
    position: relative;
    top: -0.1em;
  }
</style>
