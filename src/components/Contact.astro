---
import { contact } from '../data/content';
import { ghl, ghlReady } from '../data/ghl';
---

<section id="contact" class="section section--alt" aria-labelledby="contact-heading">
  <div class="container">
    <header class="contact-head" data-reveal>
      <span class="kicker">Connect</span>
      <h2 id="contact-heading">{contact.heading}</h2>
      <p class="contact-intro">{contact.intro}</p>
    </header>

    <div class="contact-form" data-reveal>
      {ghlReady.form ? (
        <iframe
          src={ghl.formUrl}
          title="Contact form — send Naprey a message"
          class="ghl-frame ghl-form-frame"
          loading="lazy"
          sandbox="allow-scripts allow-forms allow-same-origin allow-popups"
          aria-label="GoHighLevel contact form"
        ></iframe>
      ) : (
        <div class="ghl-placeholder" role="region" aria-label="Contact form — pending setup">
          <p class="ghl-placeholder-msg">
            The contact form will appear here once the GoHighLevel account is connected.
            In the meantime, reach Naprey directly:
          </p>
          <ul class="contact-email-list" role="list">
            {contact.emails.map((e) => (
              <li>
                <span class="contact-email-label">{e.label}</span>
                <a href={`mailto:${e.address}`} class="contact-email-link">{e.address}</a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </div>

  </div>
</section>

<script>
  // Auto-resize GHL form iframe when it broadcasts its height via postMessage
  const formFrame = document.querySelector<HTMLIFrameElement>('.ghl-form-frame');

  window.addEventListener('message', (e) => {
    if (e.origin !== 'https://api.leadconnectorhq.com') return;
    const data = typeof e.data === 'string' ? JSON.parse(e.data) : e.data;
    const height = data?.height ?? data?.['iframe-height'];
    if (!height || typeof height !== 'number') return;
    if (e.source === formFrame?.contentWindow) formFrame.style.height = `${height}px`;
  });
</script>

<style>
  .contact-head { margin-bottom: var(--space-xl); max-width: 60ch; }
  .contact-head h2 { margin-block: var(--space-xs) var(--space-md); }
  .contact-intro {
    font-size: var(--text-lg);
    color: var(--ink-soft);
    line-height: 1.5;
  }

  .contact-form { margin-bottom: var(--space-xl); }

  /* GHL iframe */
  .ghl-frame {
    width: 100%;
    border: none;
    border-radius: 12px;
    display: block;
  }
  .ghl-form-frame { min-height: 750px; }
  @media (max-width: 640px) {
    .ghl-form-frame { min-height: 680px; }
  }

  .ghl-placeholder {
    padding: var(--space-md);
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 12px;
    min-height: 200px;
  }
  .ghl-placeholder-msg {
    color: var(--ink-soft);
    margin-bottom: var(--space-sm);
  }
  .contact-email-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .contact-email-label {
    display: block;
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--ink-soft);
  }

</style>
