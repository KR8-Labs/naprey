---
import { footer, contact } from '../data/content';
---

<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">{footer.name}</p>
      <p class="footer-tagline">{footer.tagline}</p>
    </div>

    <dl class="footer-details">
      <div class="footer-dl-item">
        <dt>Phone</dt>
        <dd><a href={`tel:${contact.phone.tel}`}>{contact.phone.display}</a></dd>
      </div>
      <div class="footer-dl-item">
        <dt>Email</dt>
        <dd>
          <ul class="footer-inline" role="list">
            {contact.emails.map((e) => (
              <li><a href={`mailto:${e.address}`}>{e.address}</a></li>
            ))}
          </ul>
        </dd>
      </div>
      <div class="footer-dl-item">
        <dt>Location</dt>
        <dd>{contact.location}</dd>
      </div>
      <div class="footer-dl-item">
        <dt>Social</dt>
        <dd>
          <ul class="footer-inline" role="list">
            {contact.social.map((s) => (
              <li>
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  aria-label={`${s.platform}: ${s.label} (opens in new tab)`}
                >{s.platform} — {s.label}</a>
              </li>
            ))}
          </ul>
        </dd>
      </div>
    </dl>

    <p class="footer-copy">{footer.copy}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--ink);
    color: var(--paper-soft);
    padding-block: var(--space-xl);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--space-lg);
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    color: var(--paper);
    margin-bottom: 0.1rem;
    max-width: none;
  }
  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--paper-soft);
    max-width: none;
  }

  .footer-details {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--line-ink);
  }
  .footer-dl-item dt {
    font-size: var(--text-sm);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--paper-soft);
    margin-bottom: 0.4rem;
  }
  .footer-dl-item dd {
    color: var(--paper);
    font-size: var(--text-base);
  }
  .footer-dl-item a {
    color: var(--paper);
    text-decoration: none;
  }
  .footer-dl-item a:hover { color: var(--accent); }
  .footer-inline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .footer-copy {
    font-size: var(--text-sm);
    color: var(--paper-soft);
    max-width: none;
    padding-top: var(--space-md);
    border-top: 1px solid var(--line-ink);
  }

  @media (max-width: 700px) {
    .footer-details { grid-template-columns: 1fr 1fr; }
  }
  @media (max-width: 420px) {
    .footer-details { grid-template-columns: 1fr; }
  }
</style>
