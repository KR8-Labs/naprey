---
import { footer, contact } from '../data/content';
---

<footer class="site-footer" role="contentinfo">
  <div class="container footer-inner">
    <div class="footer-brand">
      <p class="footer-name">{footer.name}</p>
      <p class="footer-tagline">{footer.tagline}</p>
    </div>

    <nav class="footer-social" aria-label="Social media links">
      <ul role="list">
        {contact.social.map((s) => (
          <li>
            <a
              href={s.url}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={`${s.platform}: ${s.label} (opens in new tab)`}
            >
              {s.platform}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <p class="footer-copy">{footer.copy}</p>
  </div>
</footer>

<style>
  .site-footer {
    background: var(--clr-text);
    color: var(--clr-bg-alt);
    padding-block: var(--space-lg);
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr auto;
    grid-template-rows: auto auto;
    gap: var(--space-sm) var(--space-md);
    align-items: center;
  }

  @media (max-width: 600px) {
    .footer-inner {
      grid-template-columns: 1fr;
      text-align: center;
    }
    .footer-social ul {
      justify-content: center;
    }
  }

  .footer-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: 700;
    color: var(--clr-white);
    margin-bottom: 0.2rem;
    max-width: none;
  }

  .footer-tagline {
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
    letter-spacing: 0.06em;
    max-width: none;
  }

  .footer-social ul {
    display: flex;
    gap: var(--space-sm);
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .footer-social a {
    font-size: var(--text-sm);
    font-weight: 600;
    color: var(--clr-bg-alt);
    text-decoration: none;
    letter-spacing: 0.04em;
    opacity: 0.8;
    transition: opacity 0.15s;
  }
  .footer-social a:hover { opacity: 1; }

  .footer-copy {
    grid-column: 1 / -1;
    font-size: var(--text-sm);
    color: var(--clr-text-muted);
    opacity: 0.7;
    max-width: none;
  }

  @media (prefers-reduced-motion: reduce) {
    .footer-social a { transition: none; }
  }
</style>
